# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Packaging / envs
.venv/
venv/

# pypkatool run outputs (generated by `pypkatool run` with the default
# --outdir, not source). Fixture output under tests/fixtures/*/output_pypka/
# is intentionally tracked (regression test data), so this does NOT use a
# blanket "output_pypka/" rule. Older prefixes (pypkatools_/autopypka_) are
# also ignored in case leftover directories from earlier tool versions exist.
/pypkatool_*/
**/pypkatool_*/
/pypkatools_*/
**/pypkatools_*/

# Editor / OS cruft
.DS_Store
*.swp

# Local AI coding assistant config/session state — not project content
.claude/
legacy/
